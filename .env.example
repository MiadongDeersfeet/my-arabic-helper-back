# MongoDB 연결 URI (로컬 MongoDB 또는 Atlas URI)
MONGODB_URI=mongodb://localhost:27017/arabic_helper

# CORS 허용 도메인 (쉼표 구분)
ALLOWED_ORIGINS=http://localhost:5173,https://arabic-helper-front.vercel.app

# JWT 비밀키(32자 이상 권장)
JWT_SECRET=change-this-to-a-long-secret-key-at-least-32chars

# JWT 만료시간(ms)
JWT_EXPIRATION_MS=86400000

# Cloudinary (오디오 업로드)
CLOUDINARY_CLOUD_NAME=my-arabic-helper
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret
CLOUDINARY_AUDIO_FOLDER=my-arabic-helper/audio
